<Window x:Class="EXIFCleanerPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:EXIFCleanerPro"
        Title="EXIFCleaner Pro"
        Width="1160"
        Height="740"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="{StaticResource AppLogoDrawing}"
        AllowDrop="True"
        Drop="OnDrop"
        DragOver="OnDragOver"
        PreviewKeyDown="OnPreviewKeyDown"
        Closing="OnClosing"
        SizeChanged="OnSizeChanged"
        AutomationProperties.Name="EXIFCleaner Pro">
    <Window.Resources>
        <Geometry x:Key="CleanerIcon">M3,15 L9,9 L13,13 L7,19 Z M11,7 L14,4 L20,10 L17,13 Z</Geometry>
        <Geometry x:Key="HistoryIcon">M12,3 A9,9 0 1 1 5.6,5.6 L3,8 V3 H8 L6.9,4.1 A7.5,7.5 0 1 0 12,4.5 Z M11,7 H13 V12.2 L16.5,14.2 L15.5,15.9 L11,13.3 Z</Geometry>
        <Geometry x:Key="SettingsIcon">M10,2 H14 L14.7,5.1 L17.5,3.5 L20.5,6.5 L18.9,9.3 L22,10 V14 L18.9,14.7 L20.5,17.5 L17.5,20.5 L14.7,18.9 L14,22 H10 L9.3,18.9 L6.5,20.5 L3.5,17.5 L5.1,14.7 L2,14 V10 L5.1,9.3 L3.5,6.5 L6.5,3.5 L9.3,5.1 Z M12,8 A4,4 0 1 0 12,16 A4,4 0 1 0 12,8</Geometry>
        <Geometry x:Key="AddIcon">M11,3 H13 V11 H21 V13 H13 V21 H11 V13 H3 V11 H11 Z</Geometry>
        <Geometry x:Key="FolderIcon">M3,5 H10 L12,7 H21 V19 H3 Z</Geometry>
        <Geometry x:Key="CheckIcon">M4,12 L9,17 L20,6 L18.5,4.5 L9,14 L5.5,10.5 Z</Geometry>
        <Geometry x:Key="RemoveIcon">M5,11 H19 V13 H5 Z</Geometry>
        <Geometry x:Key="TrashIcon">M7,7 H17 L16,21 H8 Z M9,3 H15 L16,5 H20 V7 H4 V5 H8 Z</Geometry>
        <Geometry x:Key="PlayIcon">M7,4 L20,12 L7,20 Z</Geometry>
        <Geometry x:Key="SearchIcon">M10,3 A7,7 0 1 0 10,17 A7,7 0 1 0 10,3 M15,15 L21,21</Geometry>

        <DataTemplate x:Key="InspectorTemplate">
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                    <Grid Margin="16,14,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Image details" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedItem.FileName}" Opacity="0.7" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button x:Name="CloseCompactInspectorButton"
                                Grid.Column="1"
                                Content="Close"
                                Padding="10,6"
                                Click="OnCloseCompactInspector"
                                Visibility="Collapsed" />
                    </Grid>

                    <Border Margin="16,0" Height="150" CornerRadius="8" ClipToBounds="True"
                            Background="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
                        <Grid>
                            <Image Source="{Binding SelectedThumbnail}" Stretch="Uniform" Margin="8" />
                            <TextBlock Text="Preview unavailable" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.55">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedThumbnail}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border Margin="16,12,16,8" Padding="12" CornerRadius="9" Background="#18157F8C">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding SelectedItem.Assessment.Score}" FontSize="32" FontWeight="Bold" Foreground="#157F8C" />
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Privacy score" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedItem.Assessment.Summary}" Opacity="0.7" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ItemsControl Margin="16,0,16,4" ItemsSource="{Binding SelectedItem.Assessment.Findings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" Padding="0,7">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Category}" Opacity="0.6" FontSize="11" />
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap" Opacity="0.7" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="16,6,16,8" Padding="12" CornerRadius="9" BorderThickness="1"
                            Visibility="{Binding SelectedItem.HasComparison, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="#157F8C" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem.Comparison.VerificationPassed}" Value="False">
                                        <Setter Property="BorderBrush" Value="#D45B5B" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="Post-clean verification" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedItem.Comparison.EntryCountSummary}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding SelectedItem.Comparison.SensitiveCountSummary}" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#157F8C" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="16,4,16,8">
                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,6,6" BorderThickness="1" BorderBrush="#D45B5B"
                                Visibility="{Binding SelectedItem.HasGps, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="GPS" Foreground="#D45B5B" FontWeight="SemiBold" />
                        </Border>
                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,6,6" BorderThickness="1" BorderBrush="#157F8C"
                                Visibility="{Binding SelectedItem.HasCamera, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Camera" Foreground="#157F8C" />
                        </Border>
                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,6,6" BorderThickness="1" BorderBrush="#157F8C"
                                Visibility="{Binding SelectedItem.HasDate, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Date &amp; time" Foreground="#157F8C" />
                        </Border>
                        <Border CornerRadius="8" Padding="8,4" Margin="0,0,6,6" BorderThickness="1" BorderBrush="#157F8C"
                                Visibility="{Binding SelectedItem.HasSoftware, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Software" Foreground="#157F8C" />
                        </Border>
                        <Button Content="Show on map" Command="{Binding OpenMapCommand}" Padding="8,4" Margin="0,0,6,6"
                                Visibility="{Binding SelectedItem.HasMap, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </WrapPanel>

                    <Grid Margin="16,0,16,8">
                        <TextBox Text="{Binding MetadataSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="30,7,8,7"
                                 AutomationProperties.Name="Search metadata" />
                        <Path Data="{StaticResource SearchIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TextBox}}"
                              StrokeThickness="1.5" Width="16" Height="16" Stretch="Uniform"
                              HorizontalAlignment="Left" Margin="9,0,0,0" IsHitTestVisible="False" />
                    </Grid>

                    <ListView Margin="16,0" Height="220"
                              ItemsSource="{Binding MetadataEntries}"
                              SelectedItem="{Binding SelectedMetadataEntry}"
                              AutomationProperties.Name="Image metadata">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,5">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Group}" Opacity="0.55" FontSize="10" />
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Value}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding DisplayExplanation}" TextWrapping="Wrap" Opacity="0.6" FontSize="10" Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <WrapPanel Margin="16,10,16,14">
                        <Button Content="Copy selected" Command="{Binding CopySelectedMetadataCommand}" Padding="10,6" Margin="0,0,8,0" />
                        <Button Content="Copy all" Command="{Binding CopyAllMetadataCommand}" Padding="10,6" Margin="0,0,8,0" />
                        <Button Content="Export report" Command="{Binding ExportPrivacyReportCommand}" Padding="10,6" />
                    </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="192" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="18,22,12,22">
                    <Image Source="{StaticResource AppLogoDrawing}" Width="34" Height="34" />
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="EXIFCleaner" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="PRO" FontSize="10" Foreground="#157F8C" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static models:NavigationPage.Cleaner}"
                            AutomationProperties.Name="Cleaner page">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource CleanerIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="20" Height="20" Stretch="Uniform" />
                            <TextBlock Text="Cleaner" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static models:NavigationPage.History}"
                            AutomationProperties.Name="History page">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource HistoryIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="20" Height="20" Stretch="Uniform" />
                            <TextBlock Text="History" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="{x:Static models:NavigationPage.Settings}"
                            AutomationProperties.Name="Settings page">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource SettingsIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Width="20" Height="20" Stretch="Uniform" />
                            <TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3" Margin="12,12,12,18" Padding="12" CornerRadius="8" Background="#18157F8C">
                    <StackPanel>
                        <TextBlock Text="Local &amp; private" FontWeight="SemiBold" />
                        <TextBlock Text="Your photos never leave this device." TextWrapping="Wrap" Opacity="0.7" Margin="0,4,0,0" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <!-- Cleaner page -->
            <Grid Margin="24,20,24,20">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static models:NavigationPage.Cleaner}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Metadata cleaner" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock Text="Remove location, camera, date, and software details before sharing." Opacity="0.7" Margin="0,4,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SelectedCountText}" VerticalAlignment="Bottom" Margin="20,0,0,3" Opacity="0.7" />
                </Grid>

                <WrapPanel Grid.Row="1" Margin="0,18,0,12">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding AddFilesCommand}" AutomationProperties.Name="Add image files">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource AddIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" />
                            <TextBlock Text="Add files" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding AddFolderCommand}" AutomationProperties.Name="Add image folder">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FolderIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" />
                            <TextBlock Text="Add folder" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding SelectAllCommand}" Content="Select all" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding DeselectAllCommand}" Content="Deselect" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding RemoveSelectedCommand}" Content="Remove" />
                    <Button Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ClearQueueCommand}" Content="Clear queue" />
                    <Button x:Name="CompactDetailsButton" Style="{StaticResource ToolbarButtonStyle}" Content="Details" Click="OnOpenCompactInspector" Visibility="Collapsed" />
                </WrapPanel>

                <Border Grid.Row="2" Margin="0,0,0,12" Padding="12,9" CornerRadius="8" BorderThickness="1" BorderBrush="#157F8C">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NotificationMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Dismiss" Command="{Binding ClearNotificationCommand}" Padding="8,4" />
                        <TextBlock Text="{Binding NotificationMessage}" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition x:Name="InspectorColumn" Width="360" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                        <Grid>
                            <Border Margin="18" Padding="24" CornerRadius="12" BorderThickness="2" BorderBrush="#7F157F8C"
                                    Visibility="{Binding HasItems, Converter={StaticResource InverseBooleanConverter}, ConverterParameter=Visibility}"
                                    AutomationProperties.Name="Drop image files or folders here">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="430">
                                    <Path Data="{StaticResource AddIcon}" Fill="#157F8C" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" />
                                    <TextBlock Text="Drop photos or folders here" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,6" />
                                    <TextBlock Text="JPEG and PNG · processed locally on this device" HorizontalAlignment="Center" TextAlignment="Center" Opacity="0.65" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                        <Button Content="Choose files" Command="{Binding AddFilesCommand}" Padding="14,8" Margin="0,0,8,0" />
                                        <Button Content="Choose folder" Command="{Binding AddFolderCommand}" Padding="14,8" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="QueueGrid"
                                      ItemsSource="{Binding Items}"
                                      SelectedItem="{Binding SelectedItem}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      MouseDoubleClick="OnQueueDoubleClick"
                                      AutomationProperties.Name="Image cleaning queue">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Header="✓" Width="42" />
                                    <DataGridTemplateColumn Header="Image" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,6">
                                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ParentPath}" Opacity="0.6" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Extension}" Width="64" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="76" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Metadata" Binding="{Binding MetadataSummary}" Width="105" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="105" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <ContentControl x:Name="DesktopInspector"
                                    Grid.Column="2"
                                    Content="{Binding}"
                                    ContentTemplate="{StaticResource InspectorTemplate}"
                                    Visibility="{Binding HasSelectedItem, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>

                <Border Grid.Row="4" Margin="0,12,0,0" Style="{StaticResource CardStyle}" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Output" FontWeight="SemiBold" />
                            <TextBlock Text="Safe copies are recommended" FontSize="11" Opacity="0.65" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="18,0" VerticalAlignment="Center">
                            <ComboBox Width="190"
                                      ItemsSource="{Binding OutputModes}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Mode"
                                      SelectedValue="{Binding SelectedOutputMode}" />
                            <StackPanel Orientation="Horizontal" Margin="10,0,0,0"
                                        Visibility="{Binding IsSelectedFolderMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox Width="220" Text="{Binding OutputFolder}" IsReadOnly="True" VerticalContentAlignment="Center" />
                                <Button Content="Browse" Command="{Binding BrowseOutputFolderCommand}" Margin="6,0,0,0" Padding="10,6" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CleanCommand}" AutomationProperties.Name="Clean selected images">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource PlayIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="16" Height="16" Stretch="Uniform" />
                                <TextBlock Text="{Binding CleanButtonText}" Margin="8,0,0,0" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="5" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" AutomationProperties.LiveSetting="Polite" />
                        <ProgressBar Minimum="0" Maximum="{Binding ProgressMaximum}" Value="{Binding ProgressValue}" Height="6" Margin="0,7,16,0"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{Binding CompletionSummary}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Open output" Command="{Binding OpenOutputCommand}" Padding="10,6" Margin="0,0,8,0" />
                        <Button Content="Cancel" Command="{Binding CancelCleaningCommand}" Padding="10,6"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- History page -->
            <Grid Margin="24">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static models:NavigationPage.History}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Style="{StaticResource CardStyle}" MaxWidth="620" MaxHeight="380" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="48">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="{StaticResource HistoryIcon}" Fill="#157F8C" Width="54" Height="54" Stretch="Uniform" />
                        <Border Background="#20157F8C" CornerRadius="10" Padding="10,4" HorizontalAlignment="Center" Margin="0,22,0,12">
                            <TextBlock Text="COMING SOON" Foreground="#157F8C" FontWeight="Bold" FontSize="11" />
                        </Border>
                        <TextBlock Text="Cleaning history" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="A private, local record of completed cleaning runs will appear here in a future update. No history is stored today."
                                   TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Settings page -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static models:NavigationPage.Settings}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="24,20" MaxWidth="820" HorizontalAlignment="Left">
                    <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Choose how EXIFCleaner Pro looks and handles new cleaning runs." Opacity="0.7" Margin="0,4,0,20" />

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Follow Windows or choose a fixed light or dark theme." Opacity="0.7" Margin="0,4,16,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Cleaning defaults" FontSize="18" FontWeight="SemiBold" />
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="250" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Default output" FontWeight="SemiBold" />
                                    <TextBlock Text="Cleaned copies leave originals untouched." Opacity="0.65" FontSize="12" />
                                </StackPanel>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding OutputModes}" DisplayMemberPath="Label" SelectedValuePath="Mode" SelectedValue="{Binding SelectedOutputMode}" />
                            </Grid>
                            <Separator Margin="0,14" />
                            <CheckBox Content="Include subfolders when adding a folder" IsChecked="{Binding IncludeSubfolders}" Margin="0,0,0,10" />
                            <CheckBox Content="Open the output folder after a successful run" IsChecked="{Binding OpenOutputAfterCompletion}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Source="{StaticResource AppLogoDrawing}" Width="48" Height="48" />
                            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                <TextBlock Text="EXIFCleaner Pro" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Version 1.0 · Local-first photo metadata cleaner" Opacity="0.7" Margin="0,3,0,0" />
                                <TextBlock Text="Licensed under Apache License 2.0" Opacity="0.7" Margin="0,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="CompactInspectorPanel"
                    HorizontalAlignment="Right"
                    Width="430"
                    Margin="12"
                    Panel.ZIndex="20"
                    Visibility="Collapsed">
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource InspectorTemplate}" />
            </Border>
        </Grid>
    </Grid>
</Window>
